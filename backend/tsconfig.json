{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "types": ["node"],
    "typeRoots": ["./src/types", "./node_modules/@types"],
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
  },
  "include": ["src/**/*","prisma/**/*"],
  "exclude": ["node_modules", "dist", "tests"],
  "ts-node": {
    "files": true
  },
  "files": [
    "src/types/express.d.ts"
  ]
}